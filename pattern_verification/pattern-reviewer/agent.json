{
  "name": "pattern-reviewer",
  "displayName": "Pattern Reviewer",
  "description": "Reviews scicode-lint pattern definitions and reports issues (read-only)",
  "version": "2.0.0",
  "author": "scicode-lint team",
  "model": "sonnet",
  "systemPrompt": "system_prompt.md",
  "defaultMode": "dontAsk",
  "tools": [
    "Read",
    "Glob",
    "Grep"
  ],
  "capabilities": [
    "review-patterns",
    "validate-consistency",
    "report-issues"
  ],
  "context": {
    "patternsDirectory": "src/scicode_lint/patterns",
    "patternFormat": "TOML"
  }
}
